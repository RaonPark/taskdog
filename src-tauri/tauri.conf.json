{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskDog",
  "version": "0.1.0",
  "identifier": "com.syworks.jiratodaytodo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "TaskDog",
        "width": 380,
        "height": 620,
        "minWidth": 320,
        "minHeight": 360,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
